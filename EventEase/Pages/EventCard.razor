@using EventEase.Models
@using System.ComponentModel.DataAnnotations

<div class="card m-2 p-3 border">
    <!-- Display event details -->
    <h3>@Event.Name</h3>
    <p><strong>Date:</strong> @Event.Date.ToShortDateString()</p>
    <p><strong>Location:</strong> @Event.Location</p>

    <hr />
    <h5>Edit Event</h5>
    <!-- EditForm adds validation support -->
    <EditForm Model="@Event" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator /> <!-- Enables attribute-based validation -->
        <ValidationSummary /> <!-- Shows validation errors -->

        <!-- Bound input fields -->
        <div class="mb-2">
            <label>Name:</label>
            <InputText @bind-Value="Event.Name" class="form-control" />
        </div>
        <div class="mb-2">
            <label>Date:</label>
            <InputDate @bind-Value="Event.Date" class="form-control" />
        </div>
        <div class="mb-2">
            <label>Location:</label>
            <InputText @bind-Value="Event.Location" class="form-control" />
        </div>

        <!-- Submit button -->
        <button type="submit" class="btn btn-primary">Save</button>
    </EditForm>
</div>

@code {
    [Parameter]
    public EventModel Event { get; set; } = new EventModel();

    // Called when form passes validation
    private void HandleValidSubmit()
    {
        Console.WriteLine($"Event '{Event.Name}' updated successfully.");
    }
}