@page "/details"
@inject EventEase.Services.SessionService Session
@using EventEase.Models

<h1>Event Details</h1>

@if (selectedEvent != null)
{
    <!-- Show event info -->
    <h3>@selectedEvent.Name</h3>
    <p><strong>Date:</strong> @selectedEvent.Date.ToShortDateString()</p>
    <p><strong>Location:</strong> @selectedEvent.Location</p>

    <!-- Attendance check -->
    @if (Session.IsLoggedIn)
    {
        <p class="text-success">Welcome, @Session.UserName! You are attending this event.</p>
    }
    else
    {
        <p class="text-warning">Please register first to track attendance.</p>
    }
}
else
{
    <p>No event selected. Please choose one from the Events list.</p>
}

@code {
    // For now, we’ll just mock a selected event
    private EventModel? selectedEvent = new EventModel
    {
        Name = "Sample Event",
        Date = DateTime.Today.AddDays(5),
        Location = "Mexico City"
    };
}