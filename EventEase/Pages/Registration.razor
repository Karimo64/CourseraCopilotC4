@page "/register"
@using System.ComponentModel.DataAnnotations
@inject EventEase.Services.SessionService Session

<h1>Register for EventEase</h1>

<!-- Registration form with validation -->
<EditForm Model="@registration" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Name field -->
    <div class="mb-2">
        <label>Name:</label>
        <InputText @bind-Value="registration.Name" class="form-control" />
    </div>

    <!-- Email field -->
    <div class="mb-2">
        <label>Email:</label>
        <InputText @bind-Value="registration.Email" class="form-control" />
    </div>

    <!-- Submit button -->
    <button type="submit" class="btn btn-success">Register</button>
</EditForm>

@if (successMessage != null)
{
    <p class="text-success">@successMessage</p>
}

@code {
    // Registration model with validation rules
    public class RegistrationModel
    {
        [Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;
    }

    private RegistrationModel registration = new();
    private string? successMessage;

    // Called when form passes validation
    private void HandleValidSubmit()
    {
        // Start session when user registers
        Session.StartSession(registration.Name, registration.Email);

        successMessage = $"Thank you {registration.Name}, you are registered!";
    }
}